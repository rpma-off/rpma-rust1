{
  "name": "rpma-rust",
  "version": "0.1.0",
  "description": "RPMA v2 - Application desktop de gestion d'interventions PPF",
  "private": true,
  "scripts": {
    "dev": "npm run tauri dev",
    "dev:types": "npm run types:sync && npm run tauri dev",
    "dev:strict": "npm run types:sync && npm run types:drift-check && npm run tauri dev",
    "build": "npm run types:sync && npm run tauri build",
    "tauri": "tauri",
    "lint": "npm run frontend:lint",
    "type-check": "npm run frontend:type-check",
    "test:ci": "npm run frontend:test:ci",
    "types:sync": "cd src-tauri && cargo run --features export-types --bin export-types | node ../scripts/write-types.js",
    "types:watch": "node scripts/watch-types.js",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:install": "cd frontend && npm install",
    "frontend:lint": "cd frontend && npm run lint",
    "frontend:type-check": "cd frontend && npm run type-check",
    "frontend:encoding-check": "cd frontend && npm run encoding:check",
    "backend:build": "cd src-tauri && cargo build",
    "backend:build:release": "cd src-tauri && cargo build --release",
    "backend:check": "node -e \"require('fs').mkdirSync('frontend/.next', { recursive: true })\" && cd src-tauri && cargo check",
    "backend:clippy": "node -e \"require('fs').mkdirSync('frontend/.next', { recursive: true })\" && cd src-tauri && cargo clippy",
    "backend:fmt": "cd src-tauri && cargo fmt",
    "types:validate": "node scripts/validate-types.js",
    "types:drift-check": "node scripts/check-type-drift.js",
    "types:ci-drift-check": "node scripts/ci-type-drift-check.js",
    "ci:validate": "bash scripts/ci-type-check.sh",
    "bundle:analyze": "cd frontend && ANALYZE=true npm run build",
    "backend:architecture-check": "node scripts/backend-architecture-check.js",
    "backend:migration:fresh-db-test": "cd src-tauri && cargo test smoke_migration_harness_full --lib",
    "install": "npm run frontend:install",
    "clean": "npm run frontend:clean && cd src-tauri && cargo clean",
    "frontend:clean": "cd frontend && rm -rf node_modules .next out",
    "git:start-feature": "node scripts/git-workflow.js start-feature",
    "git:sync-feature": "node scripts/git-workflow.js sync-feature",
    "git:finish-feature": "node scripts/git-workflow.js finish-feature",
    "git:cleanup-feature": "node scripts/git-workflow.js cleanup-feature",
    "git:guard-main": "node scripts/git-workflow.js guard-main",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.1",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.6.2",
    "jsdom": "^27.1.0"
  }
}
